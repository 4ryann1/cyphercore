# Step 2: Import Libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Step 3: Load Dataset
df = pd.read_csv("academic.csv")
df.head()

# Step 4: Write Python Code
print(df.info())
print(df.describe())

# Step 5: Clean the Dataset
# Check missing values
print(df.isnull().sum())

# Fill missing Marks with mean
df['Marks'].fillna(df['Marks'].mean(), inplace=True)

# Fill missing Attendance with median
df['Attendance'].fillna(df['Attendance'].median(), inplace=True)

# Fill missing Study Hours with mean
df['Study Hours'].fillna(df['Study Hours'].mean(), inplace=True)

# Boxplot to visualize Marks outliers
plt.figure()
df.boxplot(column=['Marks'])
plt.title("Marks Outliers")
plt.show()

# Step 6: Check Outliers
Q1 = df['Marks'].quantile(0.25)
Q3 = df['Marks'].quantile(0.75)
IQR = Q3 - Q1

lower = Q1 - 1.5 * IQR
upper = Q3 + 1.5 * IQR

# Cap outliers
df['Marks'] = np.where(df['Marks'] > upper, upper, df['Marks'])
df['Marks'] = np.where(df['Marks'] < lower, lower, df['Marks'])

# Log transformation on Study Hours
df['Study Hours Log'] = np.log(df['Study Hours'] + 1)

df.head()

# Step 7: Download Output File
df.to_csv("cleaned_academic_dataset.csv", index=False)
files.download("cleaned_academic_dataset.csv")